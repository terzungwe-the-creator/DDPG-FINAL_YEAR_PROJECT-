# ── Virtual Environment (DO NOT COMMIT — 40K+ files, ~2GB) ──
.venv/
venv/
env/

# ── Python cache ──
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Training outputs (regenerated during training) ──
results/checkpoints/
results/training_log.csv
results/system.log
results/cache/
results/figures/
*.pt

# ── Evaluation outputs (regenerated during eval) ──
results/eval_raw.csv
results/eval_summary.csv
results/performance_report.json
results/dataset_preload_stats.json

# ── Large documents ──
*.docx
*.pdf

# ── Diagnostic/scratch scripts ──
diag_*.py

# ── IDE/Editor ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS files ──
.DS_Store
Thumbs.db
desktop.ini
